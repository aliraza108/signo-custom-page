{% comment %}
  SignoGrafx Custom Designer Page (iframe-only)
  - Receives design payload from iframe app
  - Builds final raster preview from layers/SVG/data URL
  - Uploads preview to Shopify Files via Next.js API
  - Adds cart line with rich properties for cart/order rendering
{% endcomment %}

<style>
html,body{margin:0;padding:0}
footer,.shopify-section-footer,#shopify-section-footer{display:none !important}
#designer-iframe{display:block;width:100%;height:calc(100vh - 80px);min-height:600px;border:0}
#sgxLoad{position:fixed;inset:0;z-index:9998;background:rgba(255,255,255,.93);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:14px;font-family:Inter,-apple-system,sans-serif;transition:opacity .3s}
#sgxLoad.hidden{opacity:0;pointer-events:none}
.sgx-ring{width:44px;height:44px;border:4px solid #e0e0e0;border-top-color:#0a8ff5;border-radius:50%;animation:sgxSpin 1s linear infinite}
@keyframes sgxSpin{to{transform:rotate(360deg)}}
.sgx-load-text{font-size:13px;color:#666;font-weight:500}
#sgxCanvas{position:fixed;left:-9999px;top:0;pointer-events:none}
</style>

<div id="sgxLoad">
  <div class="sgx-ring"></div>
  <div class="sgx-load-text">Loading designer</div>
</div>

<iframe id="designer-iframe"
  src="https://signo-custom-page.vercel.app/?product={{ product.id }}&variant={{ product.selected_or_first_available_variant.id }}"
  allow="camera;clipboard-write">
</iframe>

<canvas id="sgxCanvas"></canvas>
<script id="sgxMfRaw" type="application/json">{{ product.metafields.custom | json }}</script>

<script>
(function(){
'use strict';

const NEXTJS_URL = 'https://signo-custom-page.vercel.app';
const NEXTJS_ORIGIN = new URL(NEXTJS_URL).origin;

const FALLBACK_VARIANT_ID = {{ product.selected_or_first_available_variant.id | json }};

const iframe = document.getElementById('designer-iframe');
const loader = document.getElementById('sgxLoad');
const canvas = document.getElementById('sgxCanvas');
const ctx = canvas.getContext('2d');

let MF = {};
try { MF = JSON.parse(document.getElementById('sgxMfRaw').textContent) || {}; } catch(e) {}

function parseMfJson(v){
  if(!v || v === 'null' || v === '') return null;
  if(typeof v === 'object') return v;
  try {
    var out = JSON.parse(v);
    if(typeof out === 'string'){
      try { return JSON.parse(out); } catch(e){ return out; }
    }
    return out;
  } catch(e){
    return null;
  }
}

function toNum(v, fallback){
  var n = Number(v);
  return Number.isFinite(n) ? n : fallback;
}

function toMoney(v){
  var n = toNum(v, 0);
  return n.toFixed(2);
}

function clamp(v, min, max){
  return Math.max(min, Math.min(max, v));
}

function sanitizeDimension(v, fallback){
  return Math.max(1, Math.round(toNum(v, fallback)));
}

iframe.addEventListener('load', function(){
  setTimeout(function(){
    if(loader){
      loader.classList.add('hidden');
      setTimeout(function(){ if(loader && loader.remove) loader.remove(); }, 400);
    }
  }, 700);

  sendProductData();
  setTimeout(sendProductData, 600);
  setTimeout(sendProductData, 1400);
});

function sendProductData(){
  if(!iframe || !iframe.contentWindow) return;
  iframe.contentWindow.postMessage({
    type: 'SHOPIFY_PRODUCT_DATA',
    payload: {
      id: {{ product.id | json }},
      title: {{ product.title | json }},
      handle: {{ product.handle | json }},
      variant: { id: FALLBACK_VARIANT_ID, price: 0 },
      metafields: MF,
      sizes: Array.isArray(parseMfJson(MF.sizes)) ? parseMfJson(MF.sizes) : [],
      materials: Array.isArray(parseMfJson(MF.materials)) ? parseMfJson(MF.materials) : [],
      price_per_sqft: MF.price_per_sqft || null,
      all_metafields: MF
    }
  }, '*');
}

async function uploadToShopify(dataUrl){
  if(!dataUrl || typeof dataUrl !== 'string') throw new Error('No image payload found');
  if(dataUrl.startsWith('http')) return dataUrl;

  const res = await fetch(NEXTJS_URL + '/api/upload-design', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ imageBase64: dataUrl })
  });
  const json = await res.json().catch(function(){ return {}; });
  if(!res.ok || !json.success || !json.url){
    throw new Error(json.error || json.message || 'Upload failed');
  }
  return json.url;
}

function rasteriseSvg(svgStr, w, h){
  return new Promise(function(resolve){
    var tmp = document.createElement('canvas');
    tmp.width = sanitizeDimension(w, 1200);
    tmp.height = sanitizeDimension(h, 1200);
    var c = tmp.getContext('2d');
    if(!c){
      resolve(tmp.toDataURL('image/png', 1));
      return;
    }

    var svg = (svgStr || '').trim();
    if(!svg){
      resolve(tmp.toDataURL('image/png', 1));
      return;
    }

    if(!svg.includes('xmlns')) svg = svg.replace('<svg', '<svg xmlns="http://www.w3.org/2000/svg"');
    if(!/\bwidth\s*=/.test(svg.substring(0, 500))){
      svg = svg.replace(/(<svg[^>]*)>/, '$1 width="' + tmp.width + '" height="' + tmp.height + '">');
    }

    var blob = new Blob([svg], { type: 'image/svg+xml;charset=utf-8' });
    var url = URL.createObjectURL(blob);
    var img = new Image();
    img.onload = function(){
      c.drawImage(img, 0, 0, tmp.width, tmp.height);
      URL.revokeObjectURL(url);
      resolve(tmp.toDataURL('image/png', 1));
    };
    img.onerror = function(){
      URL.revokeObjectURL(url);
      resolve(tmp.toDataURL('image/png', 1));
    };
    img.src = url;
  });
}

function loadImg(src){
  return new Promise(function(resolve){
    var img = new Image();
    img.crossOrigin = 'anonymous';
    img.onload = function(){ resolve(img); };
    img.onerror = function(){ resolve(null); };
    img.src = src;
  });
}

async function compositeLayers(layers, W, H){
  canvas.width = sanitizeDimension(W, 1200);
  canvas.height = sanitizeDimension(H, 1200);
  ctx.fillStyle = '#ffffff';
  ctx.fillRect(0, 0, canvas.width, canvas.height);

  for(var i = 0; i < layers.length; i++){
    var l = layers[i];
    if(!l) continue;

    var x = toNum(l.x, 0);
    var y = toNum(l.y, 0);
    var w = sanitizeDimension(l.width, canvas.width);
    var h = sanitizeDimension(l.height, canvas.height);
    var op = l.opacity != null ? clamp(toNum(l.opacity, 1), 0, 1) : 1;
    var rot = toNum(l.rotation, 0);

    ctx.save();
    ctx.globalAlpha = op;
    if(rot){
      ctx.translate(x + w / 2, y + h / 2);
      ctx.rotate(rot * Math.PI / 180);
      ctx.translate(-(x + w / 2), -(y + h / 2));
    }

    try {
      var src = l.svgString ? await rasteriseSvg(l.svgString, w, h) : l.dataUrl;
      if(src){
        var imgEl = await loadImg(src);
        if(imgEl) ctx.drawImage(imgEl, x, y, w, h);
      }
    } catch(e) {}

    ctx.restore();
  }

  return canvas.toDataURL('image/png', 1);
}

async function scaleDataUrl(dataUrl, maxEdge){
  return new Promise(function(resolve){
    var img = new Image();
    img.crossOrigin = 'anonymous';
    img.onload = function(){
      var w = img.naturalWidth || img.width || 1;
      var h = img.naturalHeight || img.height || 1;
      var edge = Math.max(w, h);
      if(edge <= maxEdge){
        resolve(dataUrl);
        return;
      }
      var ratio = maxEdge / edge;
      var nw = Math.max(1, Math.round(w * ratio));
      var nh = Math.max(1, Math.round(h * ratio));
      var out = document.createElement('canvas');
      out.width = nw;
      out.height = nh;
      var c = out.getContext('2d');
      if(!c){
        resolve(dataUrl);
        return;
      }
      c.fillStyle = '#ffffff';
      c.fillRect(0, 0, nw, nh);
      c.drawImage(img, 0, 0, nw, nh);
      resolve(out.toDataURL('image/png', 0.95));
    };
    img.onerror = function(){ resolve(dataUrl); };
    img.src = dataUrl;
  });
}

async function resolveImage(data){
  var W = sanitizeDimension(data.canvasWidth, 1200);
  var H = sanitizeDimension(data.canvasHeight, 1200);

  if(data.designImageUrl && typeof data.designImageUrl === 'string' && data.designImageUrl.startsWith('http')) return data.designImageUrl;
  if(data.imageUrl && typeof data.imageUrl === 'string' && data.imageUrl.startsWith('http')) return data.imageUrl;

  if(data.customImage && typeof data.customImage === 'string' && data.customImage.startsWith('data:')){
    return await scaleDataUrl(data.customImage, 2048);
  }
  if(data.customImage && typeof data.customImage === 'string' && data.customImage.startsWith('http')){
    return data.customImage;
  }

  if(Array.isArray(data.layerData) && data.layerData.length > 0){
    var composited = await compositeLayers(data.layerData, W, H);
    return await scaleDataUrl(composited, 2048);
  }

  if(data.svgString){
    var raster = await rasteriseSvg(data.svgString, W, H);
    return await scaleDataUrl(raster, 2048);
  }

  var keys = ['custom_image','designImage','design_image','imageData','image','canvasImage','previewImage','preview','exportImage','pngData','dataUrl','dataURL','base64'];
  for(var i = 0; i < keys.length; i++){
    var v = data[keys[i]];
    if(v && typeof v === 'string' && (v.startsWith('data:') || v.startsWith('http'))){
      return v.startsWith('data:') ? await scaleDataUrl(v, 2048) : v;
    }
  }

  console.warn('[SGX] No image payload found. Keys:', Object.keys(data || {}));
  return null;
}

async function forceCartRefresh(){
  try {
    var cart = await fetch('/cart.js').then(function(r){ return r.json(); });
    var count = cart.item_count;

    document.querySelectorAll([
      '[data-cart-count]','[data-cart-item-count]','[data-cart-icon-bubble]',
      '[data-cart-badge]','.cart-count','.cart__count','.cart-count-bubble',
      '#CartCount','.js-cart-count','[data-header-cart-quantity]',
      '.cart-count-bubble span','#cart-icon-bubble span'
    ].join(',')).forEach(function(el){
      el.textContent = count;
      el.setAttribute('data-count', count);
      if(count > 0){
        el.style.display = '';
        el.removeAttribute('hidden');
      }
    });

    ['cart:refresh','cart:updated','cart:change','cart:item-added','dispatch:cart-drawer:open','dispatch:cart-drawer:refresh'].forEach(function(n){
      [document.documentElement, document, window].forEach(function(t){
        t.dispatchEvent(new CustomEvent(n, { bubbles: true, detail: { cart: cart } }));
      });
    });

    var drawer = document.querySelector('cart-drawer');
    if(drawer){
      try {
        var r = await fetch('/?sections=cart-drawer,cart-icon-bubble');
        var html = await r.json();

        if(html['cart-drawer']){
          var doc = new DOMParser().parseFromString(html['cart-drawer'], 'text/html');
          var nd = doc.querySelector('cart-drawer');
          if(nd) drawer.innerHTML = nd.innerHTML;
        }

        if(html['cart-icon-bubble']){
          var doc2 = new DOMParser().parseFromString(html['cart-icon-bubble'], 'text/html');
          document.querySelectorAll('#cart-icon-bubble').forEach(function(el){
            var n = doc2.querySelector('#cart-icon-bubble');
            if(n) el.innerHTML = n.innerHTML;
          });
        }

        if(typeof drawer.open === 'function') drawer.open();
        else drawer.setAttribute('open', '');
      } catch(e) {}
    }

    if(window.theme && window.theme.cart && window.theme.cart.getCart) window.theme.cart.getCart();
    if(window.theme && window.theme.miniCart && window.theme.miniCart.refresh) window.theme.miniCart.refresh();
    if(window.Shopify && window.Shopify.onCartUpdate) window.Shopify.onCartUpdate(cart);

  } catch(e){
    console.warn('[SGX] Cart refresh failed:', e && e.message ? e.message : e);
  }
}

window.addEventListener('message', async function(ev){
  if(!ev || !ev.data || !ev.data.type) return;

  if(ev.origin && ev.origin !== window.location.origin && ev.origin !== NEXTJS_ORIGIN) {
    return;
  }

  if(ev.data.type !== 'ADD_TO_CART') return;

  var data = ev.data || {};
  if(iframe && iframe.contentWindow){
    iframe.contentWindow.postMessage({ type: 'CART_PROCESSING' }, '*');
  }

  try {
    var qty = Math.max(1, Math.round(toNum(data.quantity || data.qty, 1)));
    var variantId = String(data.variantId || FALLBACK_VARIANT_ID);

    var unitPrice = toNum(data.unitPrice || data.price, 0);
    var linePrice = unitPrice * qty;

    var widthIn = toNum(data.canvasWidthIn || data.widthIn || (data.width ? String(data.width).replace('"','') : null), 0);
    var heightIn = toNum(data.canvasHeightIn || data.heightIn || (data.height ? String(data.height).replace('"','') : null), 0);
    var areaSqft = widthIn > 0 && heightIn > 0 ? ((widthIn * heightIn) / 144) : null;

    var imagePayload = await resolveImage(data);
    var imageUrl = null;
    if(imagePayload){
      try {
        imageUrl = await uploadToShopify(imagePayload);
      } catch(uploadErr){
        console.warn('[SGX] Upload error:', uploadErr && uploadErr.message ? uploadErr.message : uploadErr);
      }
    }

    var props = {};
    if(data.material) props['Material'] = String(data.material);
    if(data.size || data.customSize) props['Size'] = String(data.size || data.customSize);
    if(data.sides) props['Sides'] = String(data.sides);
    props['Quantity'] = String(qty);
    props['_sgx_custom_page'] = '1';

    if(unitPrice > 0) props['Unit Price'] = '$' + toMoney(unitPrice);
    if(linePrice > 0) props['Total Price'] = '$' + toMoney(linePrice);
    if(widthIn > 0) props['Width (in)'] = String(widthIn);
    if(heightIn > 0) props['Height (in)'] = String(heightIn);
    if(areaSqft != null) props['Area (sqft)'] = areaSqft.toFixed(4);

    if(imageUrl){
      props['Design Preview'] = imageUrl;
      props['_Design Preview'] = imageUrl;
      props['_Design Image URL'] = imageUrl;
      props['_preview_image'] = imageUrl;
      props['_thumbnail'] = imageUrl;
      props['_customImage'] = imageUrl;
      props['_image'] = imageUrl;
      props['_preview'] = imageUrl;
    }

    var addRes = await fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        items: [{
          id: variantId,
          quantity: qty,
          properties: props
        }]
      })
    });

    if(!addRes.ok){
      var addErr = await addRes.json().catch(function(){ return {}; });
      throw new Error(addErr.description || addErr.message || 'Cart add failed');
    }

    var addResult = await addRes.json();
    var addedItem = Array.isArray(addResult.items) ? addResult.items[0] : addResult;

    await forceCartRefresh();

    if(data.checkout){
      window.location.href = '/checkout';
    }

    if(iframe && iframe.contentWindow){
      iframe.contentWindow.postMessage({
        type: 'CART_UPDATED',
        payload: {
          success: true,
          imageUrl: imageUrl,
          itemKey: addedItem && addedItem.key ? addedItem.key : null
        }
      }, '*');
    }
  } catch(err){
    console.error('[SGX] ADD_TO_CART failed:', err);
    if(iframe && iframe.contentWindow){
      iframe.contentWindow.postMessage({
        type: 'CART_ERROR',
        payload: { success: false, error: err && err.message ? err.message : 'Unknown error' }
      }, '*');
    }
  }
});

})();
</script>
